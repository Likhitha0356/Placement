# Optional: link to Placement AI System (FastAPI) for ML predictions.
# When set, Placement Prediction page will use this API first, then fall back to the portal backend (port 5002).
# Run placement-ai-system backend (e.g. uvicorn app:app --reload) on port 8000, then set:
REACT_APP_PLACEMENT_AI_URL=http://localhost:8000

# Optional: OpenAI for AI Agent chat (otherwise uses built-in fallback)
# REACT_APP_OPENAI_API_KEY=sk-your-key
# REACT_APP_OPENAI_GPT4=true
